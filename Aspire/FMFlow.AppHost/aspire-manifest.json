{
  "$schema": "https://json.schemastore.org/aspire-8.0.json",
  "resources": {
    "FMFlowPostgreSQL": {
      "type": "parameter.v0",
      "connectionString": "{FMFlowPostgreSQL.value}",
      "value": "{FMFlowPostgreSQL.inputs.value}",
      "inputs": {
        "value": {
          "type": "string",
          "secret": true
        }
      }
    },
    "postgresUsername": {
      "type": "parameter.v0",
      "value": "{postgresUsername.inputs.value}",
      "inputs": {
        "value": {
          "type": "string",
          "secret": true
        }
      }
    },
    "postgresPassword": {
      "type": "parameter.v0",
      "value": "{postgresPassword.inputs.value}",
      "inputs": {
        "value": {
          "type": "string",
          "secret": true
        }
      }
    },
    "postgres": {
      "type": "container.v0",
      "connectionString": "Host={postgres.bindings.tcp.host};Port={postgres.bindings.tcp.port};Username={postgresUsername.value};Password={postgresPassword.value}",
      "image": "docker.io/library/postgres:17.0",
      "volumes": [
        {
          "name": "FMFlowDB",
          "target": "/var/lib/postgresql/data",
          "readOnly": false
        }
      ],
      "env": {
        "POSTGRES_HOST_AUTH_METHOD": "scram-sha-256",
        "POSTGRES_INITDB_ARGS": "--auth-host=scram-sha-256 --auth-local=scram-sha-256",
        "POSTGRES_USER": "{postgresUsername.value}",
        "POSTGRES_PASSWORD": "{postgresPassword.value}"
      },
      "bindings": {
        "tcp": {
          "scheme": "tcp",
          "protocol": "tcp",
          "transport": "tcp",
          "targetPort": 5432
        }
      }
    },
    "FMFlowDB": {
      "type": "value.v0",
      "connectionString": "{postgres.connectionString};Database=FMFlowDB"
    },
    "fmflowapi": {
      "type": "project.v0",
      "path": "../../FMFlowAPI/FMFlowAPI/FMFlowAPI.csproj",
      "env": {
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_EMIT_EXCEPTION_LOG_ATTRIBUTES": "true",
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_EMIT_EVENT_LOG_ATTRIBUTES": "true",
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_RETRY": "in_memory",
        "ASPNETCORE_FORWARDEDHEADERS_ENABLED": "true",
        "HTTP_PORTS": "{fmflowapi.bindings.http.targetPort}",
        "ConnectionStrings__FMFlowPostgreSQL": "{FMFlowPostgreSQL.connectionString}",
        "ConnectionStrings__FMFlowDB": "{FMFlowDB.connectionString}"
      },
      "bindings": {
        "http": {
          "scheme": "http",
          "protocol": "tcp",
          "transport": "http",
          "external": true
        },
        "https": {
          "scheme": "https",
          "protocol": "tcp",
          "transport": "http",
          "external": true
        }
      }
    },
    "FMFlowWeb": {
      "type": "executable.v0",
      "workingDirectory": "../../FMFlowWeb",
      "command": "npm",
      "args": [
        "run",
        "dev"
      ],
      "env": {
        "NODE_ENV": "development",
        "PORT": "{FMFlowWeb.bindings.http.targetPort}"
      },
      "bindings": {
        "http": {
          "scheme": "http",
          "protocol": "tcp",
          "transport": "http",
          "targetPort": 8000,
          "external": true
        }
      }
    }
  }
}