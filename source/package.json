{
  "name": "@fm-flow/source",
  "private": true,
  "version": "0.0.0",
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*",
    "tools/*"
  ],
  "scripts": {
    "//": "— Core Nx entry points —",
    "dev": "nx serve FMFlowWeb",
    "build": "nx build FMFlowWeb",
    "preview": "nx preview FMFlowWeb",
    "lint": "nx lint FMFlowWeb",
    "storybook": "nx storybook FMFlowWeb",
    "build-storybook": "nx build-storybook FMFlowWeb",
    "//web": "— Direct web runner fallbacks (useful while wiring targets) —",
    "dev:web": "nx serve FMFlowWeb --host --port=3000",
    "build:dev": "tsc -b && vite build --mode development",
    "build:prod": "vite build --mode production",
    "//tests": "— E2E / component tests —",
    "test:e2e": "playwright test --config=apps/FMFlowWeb/playwright.config.ts",
    "test:e2e:headed": "playwright test --config=apps/FMFlowWeb/playwright.config.ts --headed",
    "test:e2e:ui": "playwright test --config=apps/FMFlowWeb/playwright.config.ts --ui",
    "test:e2e:debug": "playwright test --config=apps/FMFlowWeb/playwright.config.ts --debug",
    "test:e2e:report": "playwright show-report",
    "test:e2e:install": "playwright install",
    "test:e2e:codegen": "playwright codegen http://localhost:3000",
    "test:components": "playwright test --config=apps/FMFlowWeb/playwright-components.config.ts",
    "test:components:headed": "playwright test --config=apps/FMFlowWeb/playwright-components.config.ts --headed",
    "test:components:ui": "playwright test --config=apps/FMFlowWeb/playwright-components.config.ts --ui",
    "test:components:debug": "playwright test --config=apps/FMFlowWeb/playwright-components.config.ts --debug",
    "test-storybook": "vitest --project=storybook"
  },
