{
	"DetailedErrors": true,
	"Logging": {
		"LogLevel": {
			"Default": "Information",
			"Microsoft.AspNetCore": "Warning"
		}
	},
	"AllowedOrigins": [
		"http://localhost:3000"
	],
	"Keycloak": {
		"realm": "fmflow",
		"auth-server-url": "http://localhost:8080",
		"ssl-required": "none",
		"resource": "fm-flow-api",
		"verify-token-audience": false,
		"credentials": {
			"secret": "YOUR_KEYCLOAK_SECRET"
		},
		"confidential-port": 0,
		"RequireHttpsMetadata": false,
		"registration-token": "YOUR_REGISTRATION_TOKEN"
	},
	"CustomJwt": {
		"SigningKey": "YOUR_JWT_SIGNING_KEY",
		"Issuer": "fmflow-app",
		"Audience": "fmflow-app",
		"MagicLinkTokenExpirationMinutes": 10,
		"InitialOnboardingTokenExpirationMinutes": 3
	},
	"MXConnect": {
		"ApiKey": "YOUR_MX_API_KEY",
		"ApiSecret": "YOUR_MX_API_SECRET",
		"BaseUrl": "https://sandbox.api.mxmerchant.com",
		"MerchantId": "1000020594"
	},
	"EmailSettings": {
		"ApiKey": "YOUR_SENDGRID_API_KEY",
		"FromEmail": "no-reply@fmflow.com",
		"FromName": "FM Flow",
		"EnableEmailService": true,
		"UseCodeTemplates": true,
		"TemplateRoot": "Templates/_Emails"
	},
	"ApiBaseUrl": "http://localhost:5104",
	"WebAppBaseUrl": "http://localhost:3000",
	"Google": {
		"PlacesApiUrl": "https://places.googleapis.com/v1",
		"PlacesApiKey": "YOUR_GOOGLE_PLACES_API_KEY",
		"UseMockPlacesService": true
	},
	"IntegrationTokenRefresh": {
		"BufferSeconds": 30
	},
	"RateLimiting": {
		"InitialOnboardingToken": {
			"PermitLimit": 3,
			"WindowMinutes": 1
		},
		"PlacesAutocomplete": {
			"TokenLimit": 5,
			"ReplenishmentPeriodSeconds": 1,
			"TokensPerPeriod": 1
		},
		"PlacesDetails": {
			"PermitLimit": 5,
			"WindowMinutes": 1
		}
	}
}