{
  "848853764585137012": {
    "targets": {
      "e2e": {
        "command": "playwright test",
        "options": {
          "cwd": "{projectRoot}"
        },
        "metadata": {
          "technologies": [
            "playwright"
          ],
          "description": "Runs Playwright Tests",
          "help": {
            "command": "npx playwright test --help",
            "example": {
              "options": {
                "workers": 1
              }
            }
          }
        },
        "parallelism": false,
        "cache": true,
        "inputs": [
          "default",
          "^production",
          {
            "externalDependencies": [
              "@playwright/test"
            ]
          }
        ],
        "outputs": [
          "{projectRoot}/test-results",
          "{projectRoot}/playwright-report"
        ]
      },
      "e2e-ci--tests/e2e/login-redirect.spec.ts": {
        "command": "playwright test tests/e2e/login-redirect.spec.ts --output=test-results\\tests-e2e-login-redirect-spec-ts",
        "options": {
          "cwd": "{projectRoot}",
          "env": {
            "PLAYWRIGHT_HTML_OUTPUT_DIR": "playwright-report\\tests-e2e-login-redirect-spec-ts",
            "PLAYWRIGHT_HTML_REPORT": "playwright-report\\tests-e2e-login-redirect-spec-ts"
          }
        },
        "metadata": {
          "technologies": [
            "playwright"
          ],
          "description": "Runs Playwright Tests in tests/e2e/login-redirect.spec.ts in CI",
          "help": {
            "command": "npx playwright test --help",
            "example": {
              "options": {
                "workers": 1
              }
            }
          }
        },
        "parallelism": false,
        "cache": true,
        "inputs": [
          "default",
          "^production",
          {
            "externalDependencies": [
              "@playwright/test"
            ]
          }
        ],
        "outputs": [
          "{projectRoot}/test-results/tests-e2e-login-redirect-spec-ts",
          "{projectRoot}/playwright-report/tests-e2e-login-redirect-spec-ts"
        ]
      },
      "e2e-ci--tests/e2e/onboarding.spec.ts": {
        "command": "playwright test tests/e2e/onboarding.spec.ts --output=test-results\\tests-e2e-onboarding-spec-ts",
        "options": {
          "cwd": "{projectRoot}",
          "env": {
            "PLAYWRIGHT_HTML_OUTPUT_DIR": "playwright-report\\tests-e2e-onboarding-spec-ts",
            "PLAYWRIGHT_HTML_REPORT": "playwright-report\\tests-e2e-onboarding-spec-ts"
          }
        },
        "metadata": {
          "technologies": [
            "playwright"
          ],
          "description": "Runs Playwright Tests in tests/e2e/onboarding.spec.ts in CI",
          "help": {
            "command": "npx playwright test --help",
            "example": {
              "options": {
                "workers": 1
              }
            }
          }
        },
        "parallelism": false,
        "cache": true,
        "inputs": [
          "default",
          "^production",
          {
            "externalDependencies": [
              "@playwright/test"
            ]
          }
        ],
        "outputs": [
          "{projectRoot}/test-results/tests-e2e-onboarding-spec-ts",
          "{projectRoot}/playwright-report/tests-e2e-onboarding-spec-ts"
        ]
      },
      "e2e-ci": {
        "executor": "nx:noop",
        "cache": true,
        "inputs": [
          "default",
          "^production",
          {
            "externalDependencies": [
              "@playwright/test"
            ]
          }
        ],
        "outputs": [
          "{projectRoot}/test-results",
          "{projectRoot}/playwright-report"
        ],
        "dependsOn": [
          {
            "target": "e2e-ci--tests/e2e/login-redirect.spec.ts",
            "projects": "self",
            "params": "forward",
            "options": "forward"
          },
          {
            "target": "e2e-ci--tests/e2e/onboarding.spec.ts",
            "projects": "self",
            "params": "forward",
            "options": "forward"
          }
        ],
        "metadata": {
          "technologies": [
            "playwright"
          ],
          "description": "Runs Playwright Tests in CI",
          "nonAtomizedTarget": "e2e",
          "help": {
            "command": "npx playwright test --help",
            "example": {
              "options": {
                "workers": 1
              }
            }
          }
        },
        "parallelism": false
      },
      "e2e-ci--merge-reports": {
        "executor": "@nx/playwright:merge-reports",
        "cache": true,
        "inputs": [
          "default",
          "^production",
          {
            "externalDependencies": [
              "@playwright/test"
            ]
          }
        ],
        "outputs": [
          "{projectRoot}/playwright-report"
        ],
        "options": {
          "config": "playwright.config.ts",
          "expectedSuites": 2
        },
        "metadata": {
          "technologies": [
            "playwright"
          ],
          "description": "Merges Playwright blob reports from atomized tasks to produce unified reports for the configured reporters."
        }
      }
    },
    "metadata": {
      "targetGroups": {
        "E2E (CI)": [
          "e2e-ci--tests/e2e/login-redirect.spec.ts",
          "e2e-ci--tests/e2e/onboarding.spec.ts",
          "e2e-ci",
          "e2e-ci--merge-reports"
        ]
      }
    }
  },
